{
  "name": "clientcast",
  "version": "0.2.0",
  "description": "AI-drafted client updates from your Git commits. Hosted approval. Scope-creep alerts with cost estimates.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "clientcast": "dist/cli.js",
    "clientcast-mcp": "dist/mcp/server.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "viewer": "cd viewer && npm run dev",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "freelance",
    "git",
    "client-updates",
    "scope-creep",
    "mcp",
    "ai-agent",
    "cli"
  ],
  "license": "MIT",
  "author": "Nikolas Sapalidis <nikolas.sapalidis@gmail.com>",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vercel/blob": "^2.3.3",
    "commander": "^12.1.0",
    "execa": "^9.5.0",
    "nanoid": "^5.0.0",
    "resend": "^6.12.2",
    "simple-git": "^3.27.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
